{
  "name": "cloudtasks-queue-sync",
  "version": "1.0.0",
  "description": "GitHub Action to sync Cloud Tasks queues with a queue.yaml file",
  "main": "dist/index.js",
  "scripts": {
    "build": "ncc build src/index.ts -o dist --source-map --license licenses.txt",
    "test": "jest",
    "test:watch": "jest --watch",
    "format": "prettier --write 'src/**/*.ts'",
    "format:check": "prettier --check 'src/**/*.ts'"
  },
  "dependencies": {
    "@actions/core": "^1.11.1",
    "@google-cloud/tasks": "^6.2.1",
    "js-yaml": "^4.1.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.13.14",
    "@vercel/ncc": "^0.38.3",
    "jest": "^29.7.0",
    "prettier": "^3.5.3",
    "ts-jest": "^29.3.1",
    "typescript": "^5.8.2"
  }
}
