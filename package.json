{
  "name": "cloudtasks-queue-sync",
  "version": "2.0.0",
  "description": "GitHub Action to sync Cloud Tasks queues with a queue.yaml file",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "package": "esbuild src/index.ts --bundle --platform=node --target=node22 --format=cjs --conditions=import --outfile=dist/index.js",
    "all": "npm run build && npm run package",
    "rebuild": "([ -d ./dist ] && rm -rf ./dist); ([ -d ./node_modules ] && rm -rf ./node_modules); NPM_CONFIG_UPDATE_NOTIFIER=false npm install --no-fund && npm run all",
    "test": "jest",
    "test:watch": "jest --watch",
    "format": "prettier --write 'src/**/*.ts'",
    "format:check": "prettier --check 'src/**/*.ts'"
  },
  "dependencies": {
    "@actions/core": "^3.0.0",
    "@google-cloud/tasks": "^6.2.1",
    "js-yaml": "^4.1.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.6.0",
    "esbuild": "^0.28.0",
    "jest": "^29.7.0",
    "prettier": "^3.8.3",
    "ts-jest": "^29.3.1",
    "typescript": "^5.9.3"
  }
}
